rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones comunes
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    // Colecciones
    
    match /usuarios/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId; // Ajustar según roles
    }

    match /productos/{productId} {
      allow read: if isAuthenticated();
      // Solo permitir crear/actualizar si tienen campos necesarios
      allow write: if isAuthenticated() 
        && request.resource.data.precio_venta is number
        && request.resource.data.cantidad is number;
      // Solo permite descontar stock o modificar si es autenticado
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated(); // Ajustar a solo admins
    }

    match /ventas/{ventaId} {
      allow read: if isAuthenticated();
      // Validar que el total sea mayor a 0 y estado válido
      allow create: if isAuthenticated() 
        && request.resource.data.total >= 0;
      allow update: if isAuthenticated();
    }
    
    match /ventas_detalle/{detalleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.cantidad > 0
        && request.resource.data.precio_unitario >= 0;
    }

    match /ventas_pagos/{pagoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /inventario_movimientos/{movId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }
    
    match /categorias/{categoriaId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Ajustar roles
    }
    
    // Por defecto todo cerrado (buena práctica)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
